# Census Bureau API (free, request at https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# TomTom (free tier, https://developer.tomtom.com/)
# Used client-side for traffic layer — restrict key to your domain
NEXT_PUBLIC_TOMTOM_API_KEY=

# Cloudflare R2 public URL for PMTiles (block group geometry)
# NEXT_PUBLIC_R2_URL=https://pub-{hash}.r2.dev/exports

# Data directories (defaults work for local development)
# DATA_DIR=./data
